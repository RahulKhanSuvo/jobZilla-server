generator client {
  provider = "prisma-client"
  output   = "../../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CANDIDATE
  EMPLOYER
  ADMIN
}

model User {
  id                        String           @id @default(uuid())
  name                      String           @db.VarChar(100)
  email                     String           @unique
  role                      UserRole         @default(CANDIDATE)
  password                  String
  views                     Int?             @default(0)
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt
  applications              Application[]
  candidate                 Candidate?
  company                   Company?
  savedJobs                 SavedJob[]
  jobViews                  JobView[]
  participantAConversations Conversation[]   @relation("ParticipantAConversations")
  participantBConversations Conversation[]   @relation("ParticipantBConversations")
  messages                  Message[]        @relation("UserMessages")
  userSettings              UserSettings?
  notifications             Notification[]
  jobs                      Job[]
  eductions                 Eduction[]
  skills                    Skill[]
  languages                 Language[]
  workExperiences           WorkExperience[]
  resumes                   Resume[]
  candidateViews            CandidateViews[] @relation("CandidateViewsAsUser")
  companyViews              CandidateViews[] @relation("CandidateViewsAsCompany")
  following                 Follow[]         @relation("UserFollowing")
  followers                 Follow[]         @relation("UserFollowers")
}

model CandidateViews {
  id String @id @default(uuid())

  userId    String
  companyId String

  user    User @relation("CandidateViewsAsUser", fields: [userId], references: [id])
  company User @relation("CandidateViewsAsCompany", fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([userId])
}
