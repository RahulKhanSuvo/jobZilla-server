generator client {
  provider = "prisma-client"
  output   = "../../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CANDIDATE
  EMPLOYER
  ADMIN
}

model User {
  id             String           @id @default(uuid())
  name           String           @db.VarChar(100)
  email          String           @unique
  role           UserRole         @default(CANDIDATE)
  password       String
  views          Int?             @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  applications   Application[]
  candidate      Candidate?
  company        Company?
  savedJobs      SavedJob[]
  jobViews       JobView[]
  candidateViews            CandidateViews[]
  participantAConversations Conversation[]   @relation("ParticipantAConversations")
  participantBConversations Conversation[]   @relation("ParticipantBConversations")
  messages                  Message[]        @relation("UserMessages")
  userSettings              UserSettings?
}

model CandidateViews {
  id        String   @id @default(uuid())
  userId    String
  companyId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  company   Company  @relation(fields: [companyId], references: [id])
}
