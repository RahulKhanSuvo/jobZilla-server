model Company {
  id           String        @id @default(uuid())
  userId       String        @unique
  description  String?
  website      String
  industry     String
  phone        String
  location     String        @db.VarChar(150)
  companySize  String
  logo         String?
  foundedDate  String?
  coverImage   String?
  facebook     String?
  linkedin     String?
  twitter      String?
  address      String?
  showProfile  Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  jobs         Job[]
  user         User          @relation(fields: [userId], references: [id])
  applications Application[]
}

enum JobType {
  FULL_TIME
  PART_TIME
  FREELANCE
  CONTRACT
  INTERN
  REMOTE
}

enum JobStatus {
  OPEN
  CLOSED
}

model Job {
  id            String        @id @default(uuid())
  title         String        @db.VarChar(100)
  description   String        @db.Text
  category      String?
  tags          String[]
  gender        String?
  salaryType    String?
  salaryMin     Int?
  salaryMax     Int?
  status        JobStatus?    @default(OPEN)
  jobType       JobType?
  experience    String?       @db.VarChar(100)
  careerLevel   String?
  qualification String?
  deadline      DateTime?
  skills        String?       @db.VarChar(200)
  companyId     String
  company       Company       @relation(fields: [companyId], references: [userId])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  applications  Application[]
  savedJobs     SavedJob[]
}

model Application {
  id        String    @id @default(uuid())
  userId    String
  jobId     String
  resumeId  String
  companyId String
  status    AppStatus @default(PENDING)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  job       Job       @relation(fields: [jobId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
  resume    Resume    @relation(fields: [resumeId], references: [id])
  company   Company   @relation(fields: [companyId], references: [id])
}

// save job
model SavedJob {
  id        String   @id @default(uuid())
  userId    String
  jobId     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  job       Job      @relation(fields: [jobId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, jobId])
}
