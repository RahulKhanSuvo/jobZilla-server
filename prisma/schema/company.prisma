model Company {
  id          String   @id @default(uuid())
  userId      String   @unique
  description String?
  website     String
  industry    Industry? @default(IT)
  phone       String
  location    String   @db.VarChar(150)
  companySize String
  logo        String?
  foundedDate String?
  coverImage  String?
  facebook    String?
  linkedin    String?
  twitter     String?
  address     String?
  showProfile Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
enum Industry {
  IT
  HR
  MARKETING
  FINANCE
  EDUCATION
  HEALTHCARE
  HOSPITALITY
  CONSTRUCTION
  MANUFACTURING
  TRANSPORTATION
  OTHER
}