model Job {
  id                String        @id @default(uuid())
  title             String        @db.VarChar(100)
  description       String
  salaryMin         Int?
  salaryMax         Int?
  jobType           JobType?
  experience        String?       @db.VarChar(100)
  deadline          DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  category          String?
  gender            String?
  qualification     String?
  salaryType        String?
  status            JobStatus?    @default(OPEN)
  totalApplications Int?          @default(0)
  careerLevel       CareerLevel?
  views             Int?          @default(0)
  companyId         String
  locationType      LocationType?
  location          String?
  applications      Application[]
  user              User          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobViews          JobView[]
  savedJobs         SavedJob[]
}

model JobView {
  id          String   @id @default(uuid())
  jobId       String
  userId      String?
  anonymousId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  job         Job      @relation(fields: [jobId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])

  @@unique([jobId, anonymousId])
  @@unique([jobId, userId])
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
  FREELANCE
}

enum JobStatus {
  OPEN
  CLOSED
  PUBLISHED
}

enum CareerLevel {
  ENTRY_LEVEL
  MID_LEVEL
  SENIOR_LEVEL
  EXECUTIVE_LEVEL
}

enum LocationType {
  REMOTE
  ON_SITE
  HYBRID
}
