model Job {
    id                String        @id @default(uuid())
    title             String        @db.VarChar(100)
    description       String        @db.Text
    category          String?
    gender            String?
    salaryType        String?
    salaryMin         Int?
    salaryMax         Int?
    totalApplications Int?          @default(0)
    status            JobStatus?    @default(OPEN)
    jobType           JobType?
    experience        String?       @db.VarChar(100)
    careerLevel       CareerLevel?
    qualification     String?
    views             Int?          @default(0)
    deadline          DateTime?
    userId            String
    user              User          @relation(fields: [userId], references: [id])
    createdAt         DateTime      @default(now())
    updatedAt         DateTime      @updatedAt
    applications      Application[]
    savedJobs         SavedJob[]
    jobViews          JobView[]
}

model JobView {
    id          String   @id @default(uuid())
    jobId       String
    userId      String?
    anonymousId String?
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    job         Job      @relation(fields: [jobId], references: [id])
    user        User?    @relation(fields: [userId], references: [id])

    @@unique([jobId, anonymousId])
    @@unique([jobId, userId])
}

enum JobType {
    FULL_TIME
    PART_TIME
    CONTRACT
    INTERN
    REMOTE
    ON_SITE
    HYBRID
}

enum JobStatus {
    OPEN
    CLOSED
    PUBLISHED
}

enum CareerLevel {
    ENTRY_LEVEL
    MID_LEVEL
    SENIOR_LEVEL
    EXECUTIVE_LEVEL
}
