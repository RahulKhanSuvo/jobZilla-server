model Eduction {
    id          String    @id @default(uuid())
    institution String
    major       String
    field       String
    startData   DateTime
    endData     DateTime?
    isStudying  Boolean   @default(false)
    createdId   DateTime  @default(now())
    candideId   String
    candidate   Candidate @relation(fields: [candideId], references: [userId])
}
