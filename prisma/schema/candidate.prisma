model Candidate {
  id                   String                @id @default(uuid())
  userId               String                @unique
  phone                String
  aboutMe              String?
  dob                  DateTime?
  facebook             String?
  gender               String?
  linkedin             String?
  location             String?
  maritalStatus        String?
  avatar               String?
  expectedSalaryMax    Int?
  expectedSalaryMin    Int?
  experienceYears      Int?
  github               String?
  preferredCareerLevel preferredCareerLevel?
  availabilityStatus   Boolean               @default(false)
  preferredCategory    preferredCategory?
  preferredJobType     preferredJobType?
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum preferredCategory {
  TECHNOLOGY
  DESIGN
  MARKETING
  SALES
  FINANCE
  HR
  OPERATIONS
  CUSTOMER_SUPPORT
  EDUCATION
  HEALTHCARE
  LEGAL
  OTHER
}

enum preferredJobType {
  FULL_TIME
  PART_TIME
  REMOTE
  HYBRID
}

enum preferredCareerLevel {
  ENTRY_LEVEL
  MID_LEVEL
  SENIOR_LEVEL
  EXECUTIVE_LEVEL
}
