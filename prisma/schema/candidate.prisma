model Candidate {
  id            String    @id @default(uuid())
  userId        String    @unique
  phone         String
  location      String?
  dob           DateTime?
  gender        String?
  maritalStatus String?
  aboutMe       String?   @db.Text
  avatar        String?
  facebook      String?
  linkedin      String?
  twitter       String?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}
